<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#222222">

    <FrameLayout
        android:id="@+id/containerCymbal1"
        android:layout_width="100dp"
        android:layout_height="100dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintLeft_toLeftOf="parent"
        app:layout_constraintRight_toLeftOf="@id/containerCymbal2"
        android:layout_marginTop="64dp">
        <View android:layout_width="match_parent" android:layout_height="match_parent" android:background="@drawable/bg_drum_cymbal1"/>
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_gravity="center" android:text="Cymbal1" android:textColor="#000000"/>
        <View android:id="@+id/highlightCymbal1" android:layout_width="match_parent" android:layout_height="match_parent" android:background="@drawable/bg_drum_highlight" android:visibility="invisible"/>
    </FrameLayout>

    <FrameLayout
        android:id="@+id/containerCymbal2"
        android:layout_width="100dp"
        android:layout_height="100dp"
        app:layout_constraintTop_toTopOf="@id/containerCymbal1"
        app:layout_constraintLeft_toRightOf="@id/containerCymbal1"
        app:layout_constraintRight_toRightOf="parent">
        <View android:layout_width="match_parent" android:layout_height="match_parent" android:background="@drawable/bg_drum_cymbal2"/>
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_gravity="center" android:text="Cymbal2" android:textColor="#000000"/>
        <View android:id="@+id/highlightCymbal2" android:layout_width="match_parent" android:layout_height="match_parent" android:background="@drawable/bg_drum_highlight" android:visibility="invisible"/>
    </FrameLayout>

    <FrameLayout
        android:id="@+id/containerTom1"
        android:layout_width="110dp"
        android:layout_height="110dp"
        app:layout_constraintTop_toBottomOf="@id/containerCymbal1"
        app:layout_constraintLeft_toLeftOf="parent"
        app:layout_constraintRight_toLeftOf="@id/containerTom2"
        android:layout_marginTop="32dp">
        <View android:layout_width="match_parent" android:layout_height="match_parent" android:background="@drawable/bg_drum_tom1"/>
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_gravity="center" android:text="Tom1" android:textColor="#000000"/>
        <View android:id="@+id/highlightTom1" android:layout_width="match_parent" android:layout_height="match_parent" android:background="@drawable/bg_drum_highlight" android:visibility="invisible"/>
    </FrameLayout>

    <FrameLayout
        android:id="@+id/containerTom2"
        android:layout_width="110dp"
        android:layout_height="110dp"
        app:layout_constraintTop_toTopOf="@id/containerTom1"
        app:layout_constraintLeft_toRightOf="@id/containerTom1"
        app:layout_constraintRight_toRightOf="parent">
        <View android:layout_width="match_parent" android:layout_height="match_parent" android:background="@drawable/bg_drum_tom2"/>
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_gravity="center" android:text="Tom2" android:textColor="#000000"/>
        <View android:id="@+id/highlightTom2" android:layout_width="match_parent" android:layout_height="match_parent" android:background="@drawable/bg_drum_highlight" android:visibility="invisible"/>
    </FrameLayout>

    <FrameLayout
        android:id="@+id/containerSnare"
        android:layout_width="120dp"
        android:layout_height="120dp"
        app:layout_constraintTop_toBottomOf="@id/containerTom1"
        app:layout_constraintLeft_toLeftOf="parent"
        app:layout_constraintRight_toLeftOf="@id/containerHihat"
        android:layout_marginTop="32dp">
        <View android:layout_width="match_parent" android:layout_height="match_parent" android:background="@drawable/bg_drum_snare"/>
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_gravity="center" android:text="Snare" android:textColor="#000000"/>
        <View android:id="@+id/highlightSnare" android:layout_width="match_parent" android:layout_height="match_parent" android:background="@drawable/bg_drum_highlight" android:visibility="invisible"/>
    </FrameLayout>

    <FrameLayout
        android:id="@+id/containerHihat"
        android:layout_width="100dp"
        android:layout_height="100dp"
        app:layout_constraintTop_toTopOf="@id/containerSnare"
        app:layout_constraintBottom_toBottomOf="@id/containerSnare"
        app:layout_constraintLeft_toRightOf="@id/containerSnare"
        app:layout_constraintRight_toRightOf="parent">
        <View android:layout_width="match_parent" android:layout_height="match_parent" android:background="@drawable/bg_drum_hihat"/>
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_gravity="center" android:text="Hi-Hat" android:textColor="#000000"/>
        <View android:id="@+id/highlightHihat" android:layout_width="match_parent" android:layout_height="match_parent" android:background="@drawable/bg_drum_highlight" android:visibility="invisible"/>
    </FrameLayout>

    <TextView
        android:id="@+id/tvResult"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Phone: None \nS-Pen: None"
        android:textColor="#FFFFFF"
        android:textSize="20sp"
        android:textAlignment="center"
        android:layout_marginBottom="32dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintLeft_toLeftOf="parent"
        app:layout_constraintRight_toRightOf="parent"/>

</androidx.constraintlayout.widget.ConstraintLayout>